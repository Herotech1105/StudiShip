<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="UTF-8">
    <title>StudyShip</title>
    <link rel="icon" href="./icons/favicon.ico" type="image/x-icon">
    <link rel="stylesheet" href="./styles/styles.css">
    <link rel="stylesheet" href="./styles/dashboard.css">

</head>
    <body>
        <header>
            <nav>
                <a href="/" class="logo">StudyShip📖</a>
                <div class="mobile-menu">
                    <a href="/createRoom">Erstellen</a>
                    <a href="/search">Suchen</a>
                    <form action="/logout" method="POST" class="logout-form">
                        <button type="submit" class="logout-link-style">Abmelden</button>
                    </form>
                </div>
            </nav>
        </header>
        <main>

            <section class="hero">

                {{#if user }}
                    <h3>Wilkommen, {{user}}!</h3>
                {{else}}
                    <h3>Dashboard</h3>
                {{/if}}
            </section>
            <div>
                <div>
                    <input id="searchBar" type="search" name="roomName" class="searchBar" >
                    <button id="submitButton" class="send-button">🔍</button>
                    <script src="../scripts/searchBar.js"></script>
                </div>
                <a href="/search" class="search-btn">Erweiterte Suche</a>

            </div>
            <div>
                <h4>Deine Lerngruppen: </h4>
                <a href="/createRoom" class="add-group-btn">Gruppe Erstellen</a>
            </div>
            <div>
                <ul>
                    {{#each rooms}}
                        <div class="room-btn">
                            <li>
                                <a href="/rooms?roomId={{this.id}}">
                                    <p class="room-btn-name">{{this.name}}</p>
                                    <p class="room-btn-subject">{{this.subject}}</p>
                                    <p class="room-btn-description">{{this.description}}</p>
                                </a>
                            </li>
                        </div>
                    {{else}}
                        <p>Du bist in keiner Gruppe</p>
                    {{/each}}
                </ul>
            </div>
        </main>
        <footer>
            <p>Diese Seite wurde erstellt von Barnabas Steiner, Tim Dorozynski, Lennart Esch und Jannis Weber</p>
            <p>Nur zur internen Verwendung an der DHBW Ravensburg Campus Friedrichshafen.</p>
            <p>Die Icons sind von fonts.google.com/icons und stehen unter der Alpha 2.0 License</p>
            <p class="attribution">"<a rel="noopener noreferrer" href="https://www.flickr.com/photos/20245378@N03/8596552756">Wendt WisCEL: group work</a>" by <a rel="noopener noreferrer" href="https://www.flickr.com/photos/20245378@N03">college.library</a> is licensed under <a rel="noopener noreferrer" href="https://creativecommons.org/licenses/by/2.0/?ref=openverse">CC BY 2.0 <img src="https://mirrors.creativecommons.org/presskit/icons/cc.svg" style="height: 1em; margin-right: 0.125em; display: inline;" /><img src="https://mirrors.creativecommons.org/presskit/icons/by.svg" style="height: 1em; margin-right: 0.125em; display: inline;" /></a>.</p>
        </footer>
    </body>
</html>